# 🧠 ① arbiterノード（複数入力→1つに統合）

👉 役割

* `/userA/cmd_vel` と `/userB/cmd_vel` を受け取る
* **優先度＋デッドマン制御**で `/cmd_vel` に出す

---

## arbiter.py

```python
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist
from std_msgs.msg import Bool

class Arbiter(Node):
    def __init__(self):
        super().__init__('arbiter')

        # Publisher
        self.pub = self.create_publisher(Twist, '/cmd_vel', 10)

        # Subscribers
        self.create_subscription(Twist, '/userA/cmd_vel', self.cb_a, 10)
        self.create_subscription(Twist, '/userB/cmd_vel', self.cb_b, 10)
        self.create_subscription(Bool, '/estop', self.cb_estop, 10)

        # 状態
        self.last_a = None
        self.last_b = None
        self.last_a_time = 0
        self.last_b_time = 0

        self.estop = False

        # パラメータ
        self.timeout = 0.5  # 秒
        self.priority = 'A'  # 'A' or 'B'

        # Timer
        self.timer = self.create_timer(0.05, self.loop)

    def cb_a(self, msg):
        self.last_a = msg
        self.last_a_time = self.get_clock().now().nanoseconds

    def cb_b(self, msg):
        self.last_b = msg
        self.last_b_time = self.get_clock().now().nanoseconds

    def cb_estop(self, msg):
        self.estop = msg.data

    def is_valid(self, last_time):
        now = self.get_clock().now().nanoseconds
        return (now - last_time) < self.timeout * 1e9

    def loop(self):
        twist = Twist()

        if self.estop:
            self.pub.publish(twist)
            return

        # 優先制御
        if self.priority == 'A':
            if self.last_a and self.is_valid(self.last_a_time):
                twist = self.last_a
            elif self.last_b and self.is_valid(self.last_b_time):
                twist = self.last_b
        else:
            if self.last_b and self.is_valid(self.last_b_time):
                twist = self.last_b
            elif self.last_a and self.is_valid(self.last_a_time):
                twist = self.last_a

        self.pub.publish(twist)


def main():
    rclpy.init()
    node = Arbiter()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()
```

