# ==========================================
# 実機がない環境用のダミーロボットクラス
# ==========================================
class MockRobot:
    def __init__(self):
        print("!!!! Mock Mode: Robot Initialized (No Hardware) !!!!")
    def enable(self):
        pass
    def disable(self):
        pass
    def run_straight(self, rpm):
        print(f"Moving: Straight {rpm} RPM")
    def run_pivot_turn(self, rpm):
        print(f"Moving: Turn {rpm} RPM")
    def run_stop(self):
        print("Moving: STOP")
    def run(self, l, r):
        print(f"Moving: L:{l}, R:{r}")

class RobotCmd(Enum):
    DISABLE = auto()
    RUN_FORWARD = auto()
    RUN_BACKWARD = auto()
    RUN_TURN_LEFT = auto()
    RUN_TURN_RIGHT = auto()
    RUN_RPM = auto()
    RUN_STOP = auto()

class RobotController(Node):
    def __init__(self):
        super().__init__('robot_controller')
        self.load_config()
        
        self.robot_cmd = RobotCmd.RUN_STOP
        self.robot_speed_rpm = 1500
        self.rpm_left = 0
        self.rpm_right = 0
        self.watchdog_count = 0
        self.WATCHDOG_COUNT_MAX = 50 # ジョイスティック時は少し長めに設定
        
        self.in_zone_1 = False
        self.in_zone_2 = False
        self.in_zone_3 = False

        self.robot = MockRobot() # 実機ならここを実機クラスに差し替え
        self.robot.enable()

        # --- ROS 2 通信設定 ---
        qos_profile = QoSProfile(reliability=ReliabilityPolicy.BEST_EFFORT, depth=10)
        self.subscription = self.create_subscription(LaserScan, '/scan', self.lidar_callback, qos_profile)
        
        self.create_timer(0.05, self.robot_loop)

        # ジョイスティック初期化
        self.init_joystick()

    def load_config(self):
        self.half_frontal_angle_rad = math.radians(90) / 2

    def init_joystick(self):
        pygame.init()
        pygame.joystick.init()
        if pygame.joystick.get_count() > 0:
            self.joy = pygame.joystick.Joystick(0)
            self.joy.init()
            print(f"Joystick Connected: {self.joy.get_name()}")
            # ジョイスティック監視スレッド開始
            threading.Thread(target=self.joystick_thread, daemon=True).start()
        else:
            print("Joystick NOT found!")

    def joystick_thread(self):
        """ジョイスティックの入力を監視してコマンドを更新する"""
        while True:
            pygame.event.pump()
            
            # F710の左スティック (Axis 1: 上下, Axis 0: 左右)
            # ※モードスイッチ(D/X)により挙動が変わるため注意
            axis_x = self.joy.get_axis(0) 
            axis_y = self.joy.get_axis(1)
            
            # デッドゾーン（遊び）の処理
            threshold = 0.2
            if axis_y < -threshold:
                self.robot_cmd = RobotCmd.RUN_FORWARD
                self.watchdog_count = 0
            elif axis_y > threshold:
                self.robot_cmd = RobotCmd.RUN_BACKWARD
                self.watchdog_count = 0
            elif axis_x < -threshold:
                self.robot_cmd = RobotCmd.RUN_TURN_LEFT
                self.watchdog_count = 0
            elif axis_x > threshold:
                self.robot_cmd = RobotCmd.RUN_TURN_RIGHT
                self.watchdog_count = 0
            else:
                self.robot_cmd = RobotCmd.RUN_STOP
            
            sleep(0.05)

    def lidar_callback(self, msg):
        # (LiDARによる障害物検知ロジック - 既存のまま)
        valid_ranges = []
        angle = msg.angle_min
        self.in_zone_1 = self.in_zone_2 = self.in_zone_3 = False
        for r in msg.ranges:
            if 0.05 < r < 10.0:
                x = r * math.cos(angle); y = r * math.sin(angle)
                if x > 0:
                    if x <= 0.22 and abs(y) <= 0.25: self.in_zone_3 = True
                    if x <= 0.55 and abs(y) <= 0.25: self.in_zone_2 = True
                    if x <= 1.05 and abs(y) <= 0.5:  self.in_zone_1 = True
            angle += msg.angle_increment

    def robot_loop(self):
        # 障害物があれば強制停止
        is_forward = self.robot_cmd in [RobotCmd.RUN_FORWARD, RobotCmd.RUN_TURN_LEFT, RobotCmd.RUN_TURN_RIGHT]
        if is_forward and self.in_zone_3:
            self.robot.run_stop()
        else:
            self.execute_robot_command()

    def execute_robot_command(self):
        speed = self.robot_speed_rpm
        if self.in_zone_2: speed *= 0.25
        elif self.in_zone_1: speed *= 0.5

        if self.robot_cmd == RobotCmd.RUN_FORWARD: self.robot.run_straight(speed)
        elif self.robot_cmd == RobotCmd.RUN_BACKWARD: self.robot.run_straight(-speed / 2)
        elif self.robot_cmd == RobotCmd.RUN_TURN_LEFT: self.robot.run_pivot_turn(-speed / 2)
        elif self.robot_cmd == RobotCmd.RUN_TURN_RIGHT: self.robot.run_pivot_turn(speed / 2)
        elif self.robot_cmd == RobotCmd.RUN_STOP: self.robot.run_stop()

if __name__ == "__main__":
    rclpy.init()
    controller = RobotController()
    try:
        rclpy.spin(controller)
    except KeyboardInterrupt:
        pass
    finally:
        controller.robot.run_stop()
        rclpy.shutdown()