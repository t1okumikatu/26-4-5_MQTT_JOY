# 🧱 具体ノード設計

## 1️⃣ arbiter_node（Python例）

```python
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist

class Arbiter(Node):
    def __init__(self):
        super().__init__('arbiter')

        self.pub = self.create_publisher(Twist, '/cmd_vel', 10)

        self.sub_a = self.create_subscription(
            Twist, '/userA/cmd_vel', self.cb_a, 10)
        self.sub_b = self.create_subscription(
            Twist, '/userB/cmd_vel', self.cb_b, 10)

        self.last_a = None
        self.last_b = None
        self.last_a_time = 0.0
        self.last_b_time = 0.0

        self.timeout = 0.5  # 秒

        self.timer = self.create_timer(0.05, self.loop)

    def cb_a(self, msg):
        self.last_a = msg
        self.last_a_time = self.get_clock().now().nanoseconds

    def cb_b(self, msg):
        self.last_b = msg
        self.last_b_time = self.get_clock().now().nanoseconds

    def loop(self):
        now = self.get_clock().now().nanoseconds
        twist = Twist()

        # A優先ロジック
        if self.last_a and (now - self.last_a_time) < self.timeout * 1e9:
            twist = self.last_a
        elif self.last_b and (now - self.last_b_time) < self.timeout * 1e9:
            twist = self.last_b
        else:
            # 安全停止
            twist.linear.x = 0.0
            twist.angular.z = 0.0

        self.pub.publish(twist)

def main():
    rclpy.init()
    node = Arbiter()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()
```

